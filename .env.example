# Копируй в .env и заполни. В Koyeb эти же значения задаются через UI → Environment variables.

# БД: по умолчанию SQLite в ./data/ (dev) или /data/ (Docker).
# Для Postgres: postgresql+psycopg2://user:pass@host/db?sslmode=require
# DB_URL=sqlite:///./data/worksplanning.db

# Общий логин/пароль для BasicAuth. Если APP_PASSWORD пуст — авторизация отключена (только для dev).
APP_USER=team
APP_PASSWORD=change-me

# Случайная строка для будущих сессий/подписей.
SESSION_SECRET=
